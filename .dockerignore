# Keep the build context lean.

.git/
.github/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.DS_Store
.idea/
.vscode/

# Output artefacts — produced by stages, not needed at build time
*.png
*.mp4
*.gif
*.zarr/
*.icechunk/
runs/
frames/

# Docs aren't needed at runtime
docs/

# Local secrets / state
*-credentials.json
kubeconfig
*.tfvars
.terraform/
*.tfstate
*.tfstate.*
